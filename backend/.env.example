# Copie este arquivo para ".env" e preencha com seus valores reais.
# NUNCA faça commit do arquivo ".env" (contém segredo).

# Secret da integracao interna do Notion (notion.so/my-integrations)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Porta em que o backend Express vai escutar
PORT=4000

# Origem permitida para CORS (URL do frontend em dev/produção)
CORS_ORIGIN=http://localhost:5173

# API key da Resend (resend.com/api-keys), usada para enviar o resumo
# diário de rotinas por e-mail. Sem ela, o endpoint de resumo continua
# funcionando (calcula o resumo normalmente) mas não envia nada.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remetente do e-mail de resumo diário. Em produção, precisa ser um
# domínio verificado na Resend — o padrão abaixo (onboarding@resend.dev)
# só funciona para testes/desenvolvimento.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Segredo compartilhado com o Vercel Cron (Settings > Environment
# Variables, mesmo valor nos dois lados). Protege o endpoint
# /api/rotinas/resumo-diario contra chamadas externas não autorizadas.
# Se não definido, o endpoint fica sem essa checagem (ok para dev local).
CRON_SECRET=

# Copie este arquivo para ".env" e preencha com seus valores reais.
# NUNCA faça commit do arquivo ".env" (contém segredo).

# Secret da integracao interna do Notion (notion.so/my-integrations)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Porta em que o backend Express vai escutar
PORT=4000

# Origem permitida para CORS (URL do frontend em dev/produção)
CORS_ORIGIN=http://localhost:5173
